# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Model
MODEL_WEIGHTS_PATH=models/weights/fsl_transformer_v1.pt
VOCABULARY_PATH=models/weights/vocabulary.json
MODEL_DEVICE=cpu

# Sliding Window
WINDOW_SIZE=30
STRIDE=10
MIN_CONFIDENCE=0.60
PAUSE_GAP_MS=800

# Upload
MAX_VIDEO_SIZE_MB=100
TEMP_UPLOAD_DIR=/tmp/fsl_uploads

# Optional: LLM post-processing
ENABLE_LLM_REWRITE=false
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
